# PRIVAZY environment template
# Copy this file to .env.local only in your private development environment.
# Do not commit real values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=PRIVAZY
NODE_ENV=development

# Auth
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace_in_private_env
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_in_private_env
SEED_ADMIN_EMAIL=replace_in_private_env
SEED_ADMIN_PASSWORD=replace_in_private_env
SEED_ADMIN_NAME=replace_in_private_env

# Supabase client-side variables
# Use the public URL and public anon/publishable key from Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=replace_in_private_env
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_in_private_env
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_in_private_env

# Supabase server-side variables
# Never expose service-role keys in client components or NEXT_PUBLIC_* variables.
SUPABASE_PROJECT_REF=replace_in_private_env
SUPABASE_ACCESS_TOKEN=replace_in_private_env
SUPABASE_SERVICE_ROLE_KEY=replace_in_private_env
SUPABASE_DB_PASSWORD=replace_in_private_env

# Database / Prisma
# DATABASE_URL should usually use the pooled connection string for serverless runtime.
# DIRECT_URL should usually use the direct/non-pooling connection string for migrations.
DATABASE_URL=replace_in_private_env
DIRECT_URL=replace_in_private_env

# Optional aliases used by some Supabase/Vercel integrations
POSTGRES_PRISMA_URL=replace_in_private_env
POSTGRES_URL_NON_POOLING=replace_in_private_env

# Vercel project linking
VERCEL_ORG_ID=replace_in_private_env
VERCEL_PROJECT_ID=replace_in_private_env
VERCEL_TOKEN=replace_in_private_env

# GitHub automation
GITHUB_TOKEN=replace_in_private_env

# Optional AI/Codex-enabled application features
OPENAI_API_KEY=replace_in_private_env

# Inngest
INNGEST_EVENT_KEY=replace_in_private_env
INNGEST_SIGNING_KEY=replace_in_private_env

# Email / Resend
RESEND_API_KEY=replace_in_private_env
RESEND_FROM=replace_in_private_env

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=replace_in_private_env
CLOUDFLARE_API_TOKEN=replace_in_private_env
CLOUDFLARE_ZONE_ID=replace_in_private_env
CLOUDFLARE_PAGES_PROJECT_NAME=replace_in_private_env
CLOUDFLARE_KV_NAMESPACE_ID=replace_in_private_env
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=replace_in_private_env
CLOUDFLARE_TURNSTILE_SECRET_KEY=replace_in_private_env

# Cloudflare R2 / S3-compatible storage, if used
CLOUDFLARE_R2_BUCKET=replace_in_private_env
CLOUDFLARE_R2_ACCESS_KEY_ID=replace_in_private_env
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace_in_private_env
R2_ACCOUNT_ID=replace_in_private_env
R2_ACCESS_KEY_ID=replace_in_private_env
R2_SECRET_ACCESS_KEY=replace_in_private_env
R2_BUCKET=replace_in_private_env
R2_ENDPOINT=replace_in_private_env
R2_PUBLIC_URL=replace_in_private_env
