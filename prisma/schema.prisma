generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  LAWYER
  OPERATOR
  CLIENT
  READ_ONLY
}

enum DocumentType {
  PRIVACY_POLICY
  RODO_POLICY
  PROCESSING_REGISTER
  PROCESSING_AGREEMENT
  DPIA
  COOKIE_POLICY
  DATA_BREACH_PROCEDURE
  DATA_SUBJECT_REQUEST_PROCEDURE
  CLEAN_DESK_POLICY
  IT_SECURITY_INSTRUCTION
  AUTHORIZATION_TEMPLATE
  TRAINING_MATERIAL
}

enum DocumentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentGenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum GeneratedDocumentStatus {
  DRAFT
  GENERATED
  DELIVERED
  ARCHIVED
}

enum FormSubmissionStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  DOCUMENT
  TEMPLATE
  PACKAGE
  SERVICE
  SUBSCRIPTION
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
  MERGED
}

enum CustomerType {
  PERSON
  COMPANY
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PAYMENT_FAILED
  CANCELLED
  FULFILLING
  COMPLETED
  REFUNDED
}

enum OrderItemStatus {
  PENDING_PAYMENT
  INPUT_REQUIRED
  IN_PROGRESS
  READY
  FULFILLED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  MOCK
  PRZELEWY24
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum InvoiceProvider {
  MOCK
  EXTERNAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  FAILED
  CANCELLED
}

enum CouponStatus {
  ACTIVE
  DISABLED
  EXPIRED
}

enum CrmLeadStatus {
  NEW
  CONTACT_REQUIRED
  CONTACTED
  QUALIFIED
  OFFER_SENT
  WON
  LOST
  ARCHIVED
}

enum CrmPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum CrmActivityType {
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
  EMAIL
  CALL
  SYSTEM
}

enum CrmMessageStatus {
  DRAFT
  QUEUED
  SENT
  FAILED
}

enum BreachIncidentStatus {
  NEW
  TRIAGE
  INVESTIGATING
  RISK_ASSESSMENT
  NOTIFICATION_REQUIRED
  NOTIFIED_AUTHORITY
  NOTIFIED_DATA_SUBJECTS
  CLOSED
  ARCHIVED
}

enum BreachRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DataSubjectRequestType {
  ACCESS
  RECTIFICATION
  ERASURE
  RESTRICTION
  PORTABILITY
  OBJECTION
  CONSENT_WITHDRAWAL
  OTHER
}

enum DataSubjectRequestStatus {
  NEW
  IDENTITY_VERIFICATION
  IN_PROGRESS
  WAITING_FOR_CLIENT
  READY_FOR_REVIEW
  RESPONDED
  CLOSED
  ARCHIVED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  passwordHash String
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfiles ClientProfile[]
  createdTemplates DocumentTemplate[] @relation("TemplateCreatedBy")
  approvedTemplates DocumentTemplate[] @relation("TemplateApprovedBy")
  generationJobs DocumentGenerationJob[]
  generatedDocuments GeneratedDocument[]
  auditLogs AuditLog[]
  formSubmissions FormSubmission[]
  carts Cart[]
  orders Order[]
  billingProfiles BillingProfile[]
  ownedCrmLeads CrmLead[] @relation("CrmLeadOwner")
  assignedCrmTasks CrmTask[] @relation("CrmTaskOwner")
  createdCrmTasks CrmTask[] @relation("CrmTaskCreatedBy")
  createdCrmNotes CrmNote[] @relation("CrmNoteCreatedBy")
  crmActivities CrmActivity[] @relation("CrmActivityActor")
  createdCrmMessages CrmMessage[] @relation("CrmMessageCreatedBy")
  crmCalendarEvents CrmCalendarEvent[] @relation("CrmCalendarEventOwner")
  assignedBreachIncidents BreachIncident[] @relation("BreachIncidentAssignedTo")
  createdBreachIncidents BreachIncident[] @relation("BreachIncidentCreatedBy")
  assignedDataSubjectRequests DataSubjectRequest[] @relation("DataSubjectRequestAssignedTo")
  createdDataSubjectRequests DataSubjectRequest[] @relation("DataSubjectRequestCreatedBy")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  nip         String?
  regon       String?
  website     String?
  email       String?
  phone       String?
  addressLine1 String?
  addressLine2 String?
  postalCode  String?
  city        String?
  country     String?  @default("PL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientProfiles ClientProfile[]
  generationJobs DocumentGenerationJob[]
  generatedDocuments GeneratedDocument[]
  auditLogs AuditLog[]
  formSubmissions FormSubmission[]
  carts Cart[]
  orders Order[]
  billingProfiles BillingProfile[]
  invoices Invoice[]
  crmLeads CrmLead[]
  crmTasks CrmTask[]
  crmNotes CrmNote[]
  crmActivities CrmActivity[]
  crmMessages CrmMessage[]
  crmCalendarEvents CrmCalendarEvent[]
  breachIncidents BreachIncident[]
  dataSubjectRequests DataSubjectRequest[]
}

model ClientProfile {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model DocumentTemplate {
  id              String @id @default(cuid())
  type            DocumentType
  name            String
  version         Int
  status          DocumentTemplateStatus @default(DRAFT)
  fileKey         String
  variablesSchema Json
  createdById     String
  approvedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("TemplateApprovedBy", fields: [approvedById], references: [id])
  generationJobs DocumentGenerationJob[]
  generatedDocuments GeneratedDocument[]

  @@unique([type, version])
  @@index([status])
}

model DocumentGenerationJob {
  id             String @id @default(cuid())
  organizationId String
  templateId     String
  status         DocumentGenerationStatus @default(PENDING)
  inputSnapshot  Json
  errorMessage   String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  template DocumentTemplate @relation(fields: [templateId], references: [id])
  createdBy User @relation(fields: [createdById], references: [id])
  generatedDocument GeneratedDocument?

  @@index([organizationId])
  @@index([templateId])
  @@index([status])
}

model GeneratedDocument {
  id              String @id @default(cuid())
  organizationId  String
  templateId      String
  templateVersion Int
  generationJobId String @unique
  type            DocumentType
  status          GeneratedDocumentStatus @default(DRAFT)
  inputSnapshot   Json
  docxFileKey     String
  pdfFileKey      String?
  zipFileKey      String?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  template DocumentTemplate @relation(fields: [templateId], references: [id])
  generationJob DocumentGenerationJob @relation(fields: [generationJobId], references: [id])
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([templateId])
  @@index([status])
}

model AuditLog {
  id             String @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  entityType     String
  entityId       String
  metadata       Json
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model FormSubmission {
  id             String @id @default(cuid())
  organizationId String
  formType       String
  status         FormSubmissionStatus @default(DRAFT)
  data           Json
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy User? @relation(fields: [createdById], references: [id])
  crmLead CrmLead?

  @@index([organizationId])
  @@index([formType])
  @@index([status])
}

model CrmLead {
  id               String        @id @default(cuid())
  organizationId   String
  formSubmissionId String?       @unique
  ownerId          String?
  status           CrmLeadStatus @default(NEW)
  priority         CrmPriority   @default(MEDIUM)
  source           String?
  utm              Json?
  valueCents       Int           @default(0)
  lostReason       String?
  lastContactedAt  DateTime?
  nextFollowUpAt   DateTime?
  wonAt            DateTime?
  lostAt           DateTime?
  archivedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formSubmission FormSubmission? @relation(fields: [formSubmissionId], references: [id], onDelete: SetNull)
  owner User? @relation("CrmLeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerId])
  @@index([status])
  @@index([priority])
  @@index([nextFollowUpAt])
}

model CrmTask {
  id             String        @id @default(cuid())
  organizationId String?
  ownerId        String?
  createdById    String?
  title          String
  description    String?
  status         CrmTaskStatus @default(OPEN)
  priority       CrmPriority   @default(MEDIUM)
  dueAt          DateTime?
  completedAt    DateTime?
  entityType     String?
  entityId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  owner User? @relation("CrmTaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy User? @relation("CrmTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerId])
  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([dueAt])
  @@index([entityType, entityId])
}

model CrmNote {
  id             String   @id @default(cuid())
  organizationId String?
  createdById    String?
  body           String
  isInternal     Boolean  @default(true)
  entityType     String?
  entityId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy User? @relation("CrmNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdById])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model CrmActivity {
  id             String          @id @default(cuid())
  organizationId String?
  actorId        String?
  type           CrmActivityType @default(SYSTEM)
  action         String
  description    String?
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime        @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor User? @relation("CrmActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorId])
  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model CrmMessage {
  id             String           @id @default(cuid())
  organizationId String?
  createdById    String?
  subject        String
  body           String
  fromEmail      String?
  toEmail        String
  status         CrmMessageStatus @default(DRAFT)
  entityType     String?
  entityId       String?
  sentAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy User? @relation("CrmMessageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model CrmCalendarEvent {
  id             String   @id @default(cuid())
  organizationId String?
  ownerId        String?
  title          String
  description    String?
  startsAt       DateTime
  endsAt         DateTime?
  status         String   @default("SCHEDULED")
  entityType     String?
  entityId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  owner User? @relation("CrmCalendarEventOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([ownerId])
  @@index([startsAt])
  @@index([entityType, entityId])
}

model BreachIncident {
  id                    String               @id @default(cuid())
  organizationId        String
  incidentNumber        String               @unique
  title                 String
  summary               String?
  status                BreachIncidentStatus @default(NEW)
  riskLevel             BreachRiskLevel      @default(MEDIUM)
  detectedAt            DateTime
  occurredAt            DateTime?
  authorityDueAt        DateTime?
  dataSubjectsDueAt     DateTime?
  assignedToId          String?
  createdById           String?
  notifyAuthority       Boolean?
  notifyDataSubjects    Boolean?
  decisionNotes         String?
  closedAt              DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("BreachIncidentAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy User? @relation("BreachIncidentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@index([riskLevel])
  @@index([authorityDueAt])
  @@index([assignedToId])
}

model DataSubjectRequest {
  id             String                   @id @default(cuid())
  organizationId String
  requestNumber  String                   @unique
  type           DataSubjectRequestType
  status         DataSubjectRequestStatus @default(NEW)
  subjectName    String
  subjectEmail   String?
  channel        String
  summary        String?
  receivedAt     DateTime
  dueAt          DateTime
  verifiedAt     DateTime?
  respondedAt    DateTime?
  assignedToId   String?
  createdById    String?
  responseSummary String?
  closedAt       DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("DataSubjectRequestAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy User? @relation("DataSubjectRequestCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([dueAt])
  @@index([assignedToId])
}

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  shortDescription String
  description      String
  status           ProductStatus @default(DRAFT)
  productType      ProductType
  priceNetCents    Int
  vatRateBps       Int           @default(2300)
  currency         String        @default("PLN")
  includedFiles    Json
  expectedDelivery String
  legalDisclaimer  String
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  variants ProductVariant[]
  cartItems CartItem[]
  orderItems OrderItem[]

  @@index([status])
  @@index([productType])
}

model ProductVariant {
  id               String        @id @default(cuid())
  productId        String
  name             String
  slug             String
  status           ProductStatus @default(ACTIVE)
  priceNetCents    Int
  vatRateBps       Int           @default(2300)
  currency         String        @default("PLN")
  includedFiles    Json
  expectedDelivery String
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]

  @@unique([productId, slug])
  @@index([status])
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  status         CouponStatus @default(ACTIVE)
  percentOffBps  Int?
  amountOffCents Int?
  currency       String       @default("PLN")
  maxRedemptions Int?
  redeemedCount  Int          @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  carts Cart[]
  orders Order[]

  @@index([status])
  @@index([expiresAt])
}

model Cart {
  id             String     @id @default(cuid())
  sessionToken   String     @unique
  status         CartStatus @default(ACTIVE)
  userId         String?
  organizationId String?
  couponId       String?
  currency       String     @default("PLN")
  subtotalNetCents Int      @default(0)
  vatCents       Int        @default(0)
  discountCents  Int        @default(0)
  totalGrossCents Int       @default(0)
  expiresAt      DateTime?
  checkedOutAt   DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User? @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  coupon Coupon? @relation(fields: [couponId], references: [id])
  items CartItem[]
  orders Order[]

  @@index([status])
  @@index([userId])
  @@index([organizationId])
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  variantId      String?
  quantity       Int      @default(1)
  unitNetCents   Int
  vatRateBps     Int
  currency       String   @default("PLN")
  productSnapshot Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
}

model BillingProfile {
  id             String       @id @default(cuid())
  customerType   CustomerType
  organizationId String?
  userId         String?
  name           String
  email          String
  phone          String?
  companyName    String?
  nip            String?
  addressLine1   String
  addressLine2   String?
  postalCode     String
  city           String
  country        String       @default("PL")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  user User? @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([email])
  @@index([nip])
  @@index([organizationId])
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  publicAccessToken String      @unique
  status            OrderStatus @default(PENDING_PAYMENT)
  userId            String?
  organizationId    String
  billingProfileId  String
  cartId            String?
  couponId          String?
  email             String
  phone             String?
  currency          String      @default("PLN")
  subtotalNetCents  Int
  vatCents          Int
  discountCents     Int         @default(0)
  totalGrossCents   Int
  source            Json?
  paidAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user User? @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  billingProfile BillingProfile @relation(fields: [billingProfileId], references: [id])
  cart Cart? @relation(fields: [cartId], references: [id])
  coupon Coupon? @relation(fields: [couponId], references: [id])
  items OrderItem[]
  payments Payment[]
  invoices Invoice[]

  @@index([status])
  @@index([organizationId])
  @@index([billingProfileId])
  @@index([email])
  @@index([createdAt])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  status          OrderItemStatus @default(PENDING_PAYMENT)
  productName     String
  productSlug     String
  productType     ProductType
  quantity        Int             @default(1)
  unitNetCents    Int
  vatRateBps      Int
  subtotalNetCents Int
  vatCents        Int
  totalGrossCents Int
  currency        String          @default("PLN")
  productSnapshot Json
  inputFormPath   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([productId])
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider @default(MOCK)
  status            PaymentStatus   @default(PENDING)
  providerPaymentId String?
  idempotencyKey    String          @unique
  amountGrossCents  Int
  currency          String          @default("PLN")
  paymentUrl        String?
  rawProviderData   Json?
  paidAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([provider, providerPaymentId])
}

model Invoice {
  id               String          @id @default(cuid())
  orderId          String
  organizationId   String
  provider         InvoiceProvider @default(MOCK)
  status           InvoiceStatus   @default(DRAFT)
  invoiceNumber    String          @unique
  externalInvoiceId String?
  externalUrl      String?
  buyerSnapshot    Json
  itemsSnapshot    Json
  subtotalNetCents Int
  vatCents         Int
  totalGrossCents  Int
  currency         String          @default("PLN")
  issuedAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([orderId])
  @@index([organizationId])
  @@index([status])
}
