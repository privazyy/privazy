generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  LAWYER
  OPERATOR
  CLIENT
  READ_ONLY
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  DPO
  BILLING
  MEMBER
  VIEWER
}

enum OrganizationMemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum DocumentType {
  PRIVACY_POLICY
  RODO_POLICY
  PROCESSING_REGISTER
  PROCESSING_AGREEMENT
  DPIA
  COOKIE_POLICY
  DATA_BREACH_PROCEDURE
  DATA_SUBJECT_REQUEST_PROCEDURE
  CLEAN_DESK_POLICY
  IT_SECURITY_INSTRUCTION
  AUTHORIZATION_TEMPLATE
  TRAINING_MATERIAL
}

enum DocumentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentGenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum GeneratedDocumentStatus {
  DRAFT
  GENERATED
  DELIVERED
  ARCHIVED
}

enum DocumentFileFormat {
  DOCX
  PDF
  HTML
  ZIP
  OTHER
}

enum DocumentReviewStatus {
  PENDING
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

enum DocumentUpdateType {
  INPUT_CHANGE
  TEMPLATE_CHANGE
  FILE_REGENERATION
  LEGAL_REVIEW
  MANUAL_CORRECTION
}

enum FormSubmissionStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductVariantStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductPackageStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CartStatus {
  OPEN
  CONVERTED
  ABANDONED
  EXPIRED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  IN_FULFILLMENT
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OrderFulfillmentStatus {
  NOT_STARTED
  QUEUED
  IN_PROGRESS
  READY
  DELIVERED
  BLOCKED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID
  CANCELLED
  CORRECTED
}

enum CouponStatus {
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
}

enum RefundStatus {
  REQUESTED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  IOD_CHECKER
  CONTACT_FORM
  NEWSLETTER
  MANUAL
  PARTNER
  IMPORT
  OTHER
}

enum LeadActivityType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  EMAIL
  CALL
  MEETING
  FORM_SUBMITTED
  CONVERTED
  TASK_CREATED
}

enum DealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BreachType {
  CONFIDENTIALITY
  INTEGRITY
  AVAILABILITY
  MIXED
  OTHER
}

enum BreachRiskLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum BreachStatus {
  REPORTED
  TRIAGE
  ASSESSING_RISK
  NOTIFIABLE
  REPORTED_TO_AUTHORITY
  SUBJECTS_NOTIFIED
  MITIGATED
  CLOSED
}

enum DataSubjectRequestType {
  ACCESS
  RECTIFICATION
  ERASURE
  RESTRICTION
  PORTABILITY
  OBJECTION
  CONSENT_WITHDRAWAL
  OTHER
}

enum IntakeChannel {
  EMAIL
  FORM
  PHONE
  LETTER
  IN_PERSON
  OTHER
}

enum DataSubjectRequestStatus {
  RECEIVED
  VERIFYING_IDENTITY
  IN_PROGRESS
  WAITING_FOR_CLIENT
  RESPONDED
  REJECTED
  CLOSED
}

enum IdentityVerificationStatus {
  NOT_STARTED
  REQUESTED
  VERIFIED
  FAILED
  NOT_REQUIRED
}

enum ClientMessageThreadStatus {
  OPEN
  WAITING_FOR_CLIENT
  WAITING_FOR_PRIVAZY
  CLOSED
}

enum ClientTaskStatus {
  OPEN
  IN_PROGRESS
  WAITING
  DONE
  CANCELLED
}

enum ComplianceReviewStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BlogPostStatus {
  DRAFT
  REVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum NewsletterSubscriberStatus {
  PENDING
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum NewsletterCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum NewsletterEventType {
  SUBSCRIBED
  CONFIRMED
  UNSUBSCRIBED
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_CLICKED
  EMAIL_BOUNCED
  COMPLAINED
}

enum ConsentType {
  MARKETING_EMAIL
  PRIVACY_POLICY
  TERMS
  PROFILING
  CONTACT
}

enum ConsentStatus {
  GRANTED
  WITHDRAWN
}

enum AutomationRuleStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AutomationRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
  ARCHIVED
}

enum NotificationType {
  SYSTEM
  TASK
  DOCUMENT
  BREACH
  DATA_SUBJECT_REQUEST
  PAYMENT
  AUTOMATION
}

enum FileObjectStatus {
  ACTIVE
  QUARANTINED
  DELETED
}

enum FilePurpose {
  DOCUMENT
  BREACH_ATTACHMENT
  MESSAGE_ATTACHMENT
  INVOICE
  CMS_ASSET
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientProfiles           ClientProfile[]
  createdTemplates         DocumentTemplate[]        @relation("TemplateCreatedBy")
  approvedTemplates        DocumentTemplate[]        @relation("TemplateApprovedBy")
  generationJobs           DocumentGenerationJob[]
  generatedDocuments       GeneratedDocument[]
  auditLogs                AuditLog[]
  formSubmissions          FormSubmission[]
  organizationInvitesSent  OrganizationInvite[]      @relation("OrganizationInviteInvitedBy")
  ownedLeads               Lead[]                    @relation("LeadOwner")
  leadActivities           LeadActivity[]            @relation("LeadActivityAuthor")
  leadNotes                LeadNote[]                @relation("LeadNoteAuthor")
  ownedDeals               Deal[]                    @relation("DealOwner")
  crmTasksAssigned         CrmTask[]                 @relation("CrmTaskAssignee")
  crmTasksCreated          CrmTask[]                 @relation("CrmTaskCreator")
  carts                    Cart[]
  orders                   Order[]
  payments                 Payment[]
  invoiceIssued            Invoice[]                 @relation("InvoiceIssuedBy")
  refundsRequested         Refund[]                  @relation("RefundRequestedBy")
  documentTemplateVersions DocumentTemplateVersion[] @relation("DocumentTemplateVersionCreatedBy")
  approvedTemplateVersions DocumentTemplateVersion[] @relation("DocumentTemplateVersionApprovedBy")
  documentInputs           DocumentInput[]
  documentDownloads        DocumentDownload[]
  documentReviews          DocumentReview[]          @relation("DocumentReviewReviewer")
  documentUpdates          DocumentUpdate[]          @relation("DocumentUpdateAuthor")
  breachReports            BreachIncident[]          @relation("BreachReporter")
  breachAssignments        BreachIncident[]          @relation("BreachAssignedTo")
  breachAttachments        BreachAttachment[]        @relation("BreachAttachmentUploadedBy")
  breachComments           BreachComment[]           @relation("BreachCommentAuthor")
  breachTimelineEvents     BreachTimelineEvent[]     @relation("BreachTimelineActor")
  dataSubjectRequests      DataSubjectRequest[]      @relation("DataSubjectRequestAssignedTo")
  dataSubjectRequestEvents DataSubjectRequestEvent[] @relation("DataSubjectRequestEventActor")
  clientMessageThreads     ClientMessageThread[]     @relation("ClientMessageThreadCreatedBy")
  assignedMessageThreads   ClientMessageThread[]     @relation("ClientMessageThreadAssignedTo")
  clientMessages           ClientMessage[]           @relation("ClientMessageSender")
  clientTasksAssigned      ClientTask[]              @relation("ClientTaskAssignee")
  clientTasksCreated       ClientTask[]              @relation("ClientTaskCreator")
  complianceReviews        ComplianceReview[]        @relation("ComplianceReviewReviewer")
  blogPosts                BlogPost[]                @relation("BlogPostAuthor")
  blogReviews              BlogPost[]                @relation("BlogPostReviewer")
  blogRevisions            BlogRevision[]            @relation("BlogRevisionAuthor")
  newsletterCampaigns      NewsletterCampaign[]      @relation("NewsletterCampaignCreatedBy")
  marketingEvents          MarketingEvent[]
  consentRecords           ConsentRecord[]
  automationRules          AutomationRule[]          @relation("AutomationRuleCreatedBy")
  notifications            Notification[]
  uploadedFiles            FileObject[]              @relation("FileObjectUploadedBy")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  nip          String?
  regon        String?
  website      String?
  email        String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  postalCode   String?
  city         String?
  country      String?  @default("PL")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientProfiles        ClientProfile[]
  invites               OrganizationInvite[]
  billingProfile        BillingProfile?
  settings              OrganizationSettings?
  generationJobs        DocumentGenerationJob[]
  generatedDocuments    GeneratedDocument[]
  auditLogs             AuditLog[]
  formSubmissions       FormSubmission[]
  leads                 Lead[]                  @relation("LeadOrganization")
  convertedLeads        Lead[]                  @relation("LeadConvertedOrganization")
  deals                 Deal[]
  pipelineStages        PipelineStage[]
  contactPeople         ContactPerson[]
  crmTasks              CrmTask[]
  carts                 Cart[]
  orders                Order[]
  payments              Payment[]
  invoices              Invoice[]
  documentInputs        DocumentInput[]
  documentDownloads     DocumentDownload[]
  breachIncidents       BreachIncident[]
  dataSubjectRequests   DataSubjectRequest[]
  clientMessageThreads  ClientMessageThread[]
  clientTasks           ClientTask[]
  complianceReviews     ComplianceReview[]
  complianceScores      ComplianceScore[]
  newsletterSubscribers NewsletterSubscriber[]
  marketingEvents       MarketingEvent[]
  consentRecords        ConsentRecord[]
  automationRules       AutomationRule[]
  notifications         Notification[]
  files                 FileObject[]
}

model ClientProfile {
  id               String                   @id @default(cuid())
  userId           String
  organizationId   String
  organizationRole OrganizationMemberRole   @default(MEMBER)
  status           OrganizationMemberStatus @default(ACTIVE)
  title            String?
  invitedAt        DateTime?
  acceptedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([organizationRole])
  @@index([status, createdAt])
}

model OrganizationInvite {
  id             String                   @id @default(cuid())
  organizationId String
  email          String
  role           OrganizationMemberRole   @default(MEMBER)
  status         OrganizationInviteStatus @default(PENDING)
  token          String                   @unique
  invitedById    String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("OrganizationInviteInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model BillingProfile {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  legalName         String
  taxId             String?
  vatEu             String?
  email             String?
  addressLine1      String?
  addressLine2      String?
  postalCode        String?
  city              String?
  country           String   @default("PL")
  invoiceProvider   String?
  providerAccountId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([taxId])
  @@index([createdAt])
}

model OrganizationSettings {
  id                           String   @id @default(cuid())
  organizationId               String   @unique
  defaultCurrency              String   @default("PLN")
  defaultLocale                String   @default("pl-PL")
  breachNotificationEmail      String?
  dataRequestNotificationEmail String?
  settings                     Json?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ProductCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([sortOrder])
  @@index([createdAt])
}

model Product {
  id               String        @id @default(cuid())
  categoryId       String?
  name             String
  slug             String        @unique
  status           ProductStatus @default(DRAFT)
  shortDescription String?
  description      String?
  defaultCurrency  String        @default("PLN")
  sortOrder        Int           @default(0)
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  category     ProductCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants     ProductVariant[]
  packageItems ProductPackageItem[]

  @@index([categoryId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model ProductVariant {
  id               String               @id @default(cuid())
  productId        String
  templateId       String?
  name             String
  sku              String?              @unique
  status           ProductVariantStatus @default(DRAFT)
  currency         String               @default("PLN")
  netAmountCents   Int
  grossAmountCents Int
  vatRateBps       Int                  @default(2300)
  vatAmountCents   Int
  fulfillmentDays  Int?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  template            DocumentTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  cartItems           CartItem[]
  orderItems          OrderItem[]
  productPackageItems ProductPackageItem[]

  @@index([productId])
  @@index([templateId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model ProductPackage {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  status           ProductPackageStatus @default(DRAFT)
  description      String?
  currency         String               @default("PLN")
  netAmountCents   Int
  grossAmountCents Int
  vatRateBps       Int                  @default(2300)
  vatAmountCents   Int
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  items      ProductPackageItem[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([status, createdAt])
  @@index([createdAt])
}

model ProductPackageItem {
  id               String  @id @default(cuid())
  packageId        String
  productId        String
  productVariantId String?
  quantity         Int     @default(1)
  sortOrder        Int     @default(0)

  package        ProductPackage  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@unique([packageId, productId, productVariantId])
  @@index([productId])
  @@index([productVariantId])
}

model Cart {
  id             String     @id @default(cuid())
  organizationId String?
  userId         String?
  couponId       String?
  status         CartStatus @default(OPEN)
  currency       String     @default("PLN")
  subtotalCents  Int        @default(0)
  discountCents  Int        @default(0)
  taxCents       Int        @default(0)
  totalCents     Int        @default(0)
  anonymousId    String?
  expiresAt      DateTime?
  convertedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupon       Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items        CartItem[]
  orders       Order[]

  @@index([organizationId])
  @@index([userId])
  @@index([couponId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model CartItem {
  id                   String   @id @default(cuid())
  cartId               String
  productVariantId     String?
  packageId            String?
  quantity             Int      @default(1)
  currency             String   @default("PLN")
  unitNetAmountCents   Int
  unitGrossAmountCents Int
  vatRateBps           Int      @default(2300)
  vatAmountCents       Int
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  package        ProductPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([cartId])
  @@index([productVariantId])
  @@index([packageId])
}

model Order {
  id                String                 @id @default(cuid())
  orderNumber       String                 @unique
  organizationId    String?
  userId            String?
  cartId            String?
  couponId          String?
  status            OrderStatus            @default(PENDING_PAYMENT)
  paymentStatus     PaymentStatus          @default(PENDING)
  fulfillmentStatus OrderFulfillmentStatus @default(NOT_STARTED)
  currency          String                 @default("PLN")
  subtotalCents     Int
  discountCents     Int                    @default(0)
  taxCents          Int
  totalCents        Int
  billingEmail      String?
  customerNote      String?
  placedAt          DateTime?
  paidAt            DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  cart           Cart?         @relation(fields: [cartId], references: [id], onDelete: SetNull)
  coupon         Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]
  invoice        Invoice?
  refunds        Refund[]
  convertedLeads Lead[]        @relation("LeadConvertedOrder")
  deals          Deal[]

  @@index([organizationId])
  @@index([userId])
  @@index([cartId])
  @@index([couponId])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([fulfillmentStatus, createdAt])
  @@index([createdAt])
}

model OrderItem {
  id                    String   @id @default(cuid())
  orderId               String
  productVariantId      String?
  packageId             String?
  name                  String
  sku                   String?
  quantity              Int      @default(1)
  currency              String   @default("PLN")
  unitNetAmountCents    Int
  unitGrossAmountCents  Int
  vatRateBps            Int      @default(2300)
  vatAmountCents        Int
  totalGrossAmountCents Int
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant     ProductVariant?     @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  package            ProductPackage?     @relation(fields: [packageId], references: [id], onDelete: SetNull)
  documentInputs     DocumentInput[]
  generatedDocuments GeneratedDocument[]
  invoiceLines       InvoiceLine[]

  @@index([orderId])
  @@index([productVariantId])
  @@index([packageId])
  @@index([createdAt])
}

model Payment {
  id                  String        @id @default(cuid())
  orderId             String
  organizationId      String?
  userId              String?
  provider            String
  providerPaymentId   String?
  status              PaymentStatus @default(PENDING)
  currency            String        @default("PLN")
  amountCents         Int
  capturedAmountCents Int           @default(0)
  refundedAmountCents Int           @default(0)
  failureCode         String?
  failureMessage      String?
  metadata            Json?
  authorizedAt        DateTime?
  capturedAt          DateTime?
  failedAt            DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  refunds      Refund[]

  @@unique([provider, providerPaymentId])
  @@index([orderId])
  @@index([organizationId])
  @@index([userId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Invoice {
  id                String        @id @default(cuid())
  organizationId    String
  orderId           String?       @unique
  billingProfileId  String?
  issuedById        String?
  number            String        @unique
  status            InvoiceStatus @default(DRAFT)
  currency          String        @default("PLN")
  netAmountCents    Int
  vatAmountCents    Int
  grossAmountCents  Int
  provider          String?
  providerInvoiceId String?
  fileKey           String?
  issuedAt          DateTime?
  dueAt             DateTime?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  order          Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  billingProfile BillingProfile? @relation(fields: [billingProfileId], references: [id], onDelete: SetNull)
  issuedBy       User?           @relation("InvoiceIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]

  @@unique([provider, providerInvoiceId])
  @@index([organizationId])
  @@index([billingProfileId])
  @@index([issuedById])
  @@index([status, createdAt])
  @@index([createdAt])
}

model InvoiceLine {
  id                 String   @id @default(cuid())
  invoiceId          String
  orderItemId        String?
  description        String
  quantity           Int      @default(1)
  unitNetAmountCents Int
  vatRateBps         Int      @default(2300)
  vatAmountCents     Int
  grossAmountCents   Int
  createdAt          DateTime @default(now())

  invoice   Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([orderItemId])
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String?
  status         CouponStatus @default(ACTIVE)
  discountType   DiscountType
  discountValue  Int
  currency       String       @default("PLN")
  maxRedemptions Int?
  redeemedCount  Int          @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  carts  Cart[]
  orders Order[]

  @@index([status, createdAt])
  @@index([expiresAt])
}

model Refund {
  id               String       @id @default(cuid())
  orderId          String
  paymentId        String
  requestedById    String?
  status           RefundStatus @default(REQUESTED)
  currency         String       @default("PLN")
  amountCents      Int
  reason           String?
  providerRefundId String?
  processedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  requestedBy User?   @relation("RefundRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

