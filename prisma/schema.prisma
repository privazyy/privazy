generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  LAWYER
  OPERATOR
  CLIENT
  READ_ONLY
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  MEMBER
  BILLING
  VIEWER
}

enum OrganizationMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductKind {
  DOCUMENT
  PACKAGE
  SERVICE
  SUBSCRIPTION
}

enum ProductVariantStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
  EXPIRED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  IN_FULFILLMENT
  COMPLETED
  CANCELLED
  REFUNDED
  FAILED
}

enum OrderItemStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  BANK_TRANSFER
  MANUAL
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID
  CANCELLED
  OVERDUE
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  ARCHIVED
}

enum RefundStatus {
  REQUESTED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  IOD_CHECKER
  WEBSITE
  BLOG
  SHOP
  MANUAL
  REFERRAL
  CAMPAIGN
}

enum LeadActivityType {
  CREATED
  EMAIL
  PHONE
  MEETING
  NOTE
  STATUS_CHANGE
  CONVERTED
  TASK
}

enum DealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum CrmTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PipelineStageKind {
  LEAD
  DEAL
  ORDER
}

enum ContactPersonRole {
  PRIMARY
  BILLING
  TECHNICAL
  LEGAL
  DPO
  OTHER
}

enum BreachType {
  CONFIDENTIALITY
  INTEGRITY
  AVAILABILITY
  PHISHING
  LOSS
  THEFT
  MISDIRECTED_EMAIL
  UNAUTHORIZED_ACCESS
  OTHER
}

enum BreachRiskLevel {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

enum BreachStatus {
  REPORTED
  TRIAGE
  IN_PROGRESS
  NOTIFIED_AUTHORITY
  NOTIFIED_SUBJECTS
  CLOSED
  ARCHIVED
}

enum DataSubjectRequestType {
  ACCESS
  RECTIFICATION
  ERASURE
  RESTRICTION
  PORTABILITY
  OBJECTION
  WITHDRAW_CONSENT
  OTHER
}

enum DataSubjectRequestStatus {
  RECEIVED
  VERIFYING_IDENTITY
  IN_PROGRESS
  WAITING_FOR_CLIENT
  RESPONDED
  REJECTED
  CLOSED
  ARCHIVED
}

enum DataSubjectRequestChannel {
  FORM
  EMAIL
  PHONE
  LETTER
  IN_PERSON
  OTHER
}

enum IdentityVerificationStatus {
  NOT_REQUIRED
  PENDING
  VERIFIED
  FAILED
}

enum ClientThreadStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum ClientTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ClientTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplianceReviewStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ComplianceScoreLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DocumentType {
  PRIVACY_POLICY
  RODO_POLICY
  PROCESSING_REGISTER
  PROCESSING_AGREEMENT
  DPIA
  COOKIE_POLICY
  DATA_BREACH_PROCEDURE
  DATA_SUBJECT_REQUEST_PROCEDURE
  CLEAN_DESK_POLICY
  IT_SECURITY_INSTRUCTION
  AUTHORIZATION_TEMPLATE
  TRAINING_MATERIAL
}

enum DocumentTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum DocumentGenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentInputStatus {
  DRAFT
  SUBMITTED
  LOCKED
  ARCHIVED
}

enum GeneratedDocumentStatus {
  DRAFT
  GENERATED
  DELIVERED
  ARCHIVED
}

enum DocumentFileType {
  DOCX
  PDF
  HTML
  ZIP
  OTHER
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum DocumentUpdateType {
  CREATED
  REGENERATED
  REPLACED
  REVIEWED
  DELIVERED
  ARCHIVED
}

enum FormSubmissionStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
}

enum BlogPostStatus {
  DRAFT
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum NewsletterSubscriberStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  PENDING
}

enum NewsletterCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
  FAILED
}

enum NewsletterEventType {
  SUBSCRIBED
  UNSUBSCRIBED
  SENT
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
}

enum MarketingEventType {
  PAGE_VIEW
  CTA_CLICK
  FORM_SUBMIT
  CHECKER_COMPLETED
  PRODUCT_VIEW
  CART_ADD
  CHECKOUT_START
  PURCHASE
}

enum AutomationTriggerType {
  LEAD_CREATED
  ORDER_PAID
  DOCUMENT_GENERATED
  BREACH_REPORTED
  DATA_SUBJECT_REQUEST_RECEIVED
  SCHEDULED
  MANUAL
}

enum AutomationTargetType {
  EMAIL
  NOTIFICATION
  TASK
  WEBHOOK
}

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationType {
  INFO
  WARNING
  TASK
  SYSTEM
  SECURITY
}

enum FileAssetPurpose {
  DOCUMENT_TEMPLATE
  GENERATED_DOCUMENT
  BREACH_ATTACHMENT
  MESSAGE_ATTACHMENT
  IMPORT
  EXPORT
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs                    AuditLog[]
  automationRulesCreated       AutomationRule[]          @relation("AutomationRuleCreatedBy")
  blogPosts                    BlogPost[]                @relation("BlogPostAuthor")
  blogRevisions                BlogRevision[]            @relation("BlogRevisionEditor")
  breachAttachmentsUploaded    BreachAttachment[]        @relation("BreachAttachmentUploadedBy")
  breachComments               BreachComment[]           @relation("BreachCommentAuthor")
  breachIncidentsAssigned      BreachIncident[]          @relation("BreachAssignedTo")
  breachIncidentsReported      BreachIncident[]          @relation("BreachReportedBy")
  breachTimelineEvents         BreachTimelineEvent[]     @relation("BreachTimelineCreatedBy")
  clientMessages               ClientMessage[]           @relation("ClientMessageSender")
  clientProfiles               ClientProfile[]
  clientTasksAssigned          ClientTask[]              @relation("ClientTaskAssignedTo")
  clientTasksCreated           ClientTask[]              @relation("ClientTaskCreatedBy")
  complianceReviewsAssigned    ComplianceReview[]        @relation("ComplianceReviewAssignedTo")
  complianceReviewsCreated     ComplianceReview[]        @relation("ComplianceReviewCreatedBy")
  createdTemplates             DocumentTemplate[]        @relation("TemplateCreatedBy")
  crmTasksAssigned             CrmTask[]                 @relation("CrmTaskAssignedTo")
  crmTasksCreated              CrmTask[]                 @relation("CrmTaskCreatedBy")
  dataSubjectRequestsAssigned  DataSubjectRequest[]      @relation("DsrAssignedTo")
  dataSubjectRequestEvents     DataSubjectRequestEvent[] @relation("DsrEventCreatedBy")
  documentDownloads            DocumentDownload[]        @relation("DocumentDownloadUser")
  documentInputs               DocumentInput[]           @relation("DocumentInputCreatedBy")
  documentReviews              DocumentReview[]          @relation("DocumentReviewReviewer")
  documentTemplateVersionsMade DocumentTemplateVersion[] @relation("TemplateVersionCreatedBy")
  documentUpdates              DocumentUpdate[]          @relation("DocumentUpdateUser")
  fileAssets                   FileAsset[]               @relation("FileAssetUploadedBy")
  formSubmissions              FormSubmission[]
  generatedDocuments           GeneratedDocument[]
  generationJobs               DocumentGenerationJob[]
  leadActivities               LeadActivity[]            @relation("LeadActivityCreatedBy")
  leadNotes                    LeadNote[]                @relation("LeadNoteCreatedBy")
  newsletterCampaigns          NewsletterCampaign[]      @relation("NewsletterCampaignCreatedBy")
  notifications                Notification[]
  organizationInvitesSent      OrganizationInvite[]      @relation("OrganizationInviteInvitedBy")
  organizationMemberships      OrganizationUser[]
  ordersCreated                Order[]                   @relation("OrderCreatedBy")
  ordersCustomer               Order[]                   @relation("OrderCustomer")
  ownedDeals                   Deal[]                    @relation("DealOwner")
  ownedLeads                   Lead[]                    @relation("LeadOwner")

  approvedTemplates        DocumentTemplate[]        @relation("TemplateApprovedBy")
  approvedTemplateVersions DocumentTemplateVersion[] @relation("TemplateVersionApprovedBy")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  nip          String?
  regon        String?
  website      String?
  email        String?
  phone        String?
  addressLine1 String?
  addressLine2 String?
  postalCode   String?
  city         String?
  country      String?  @default("PL")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs            AuditLog[]
  billingProfiles      BillingProfile[]
  breachIncidents      BreachIncident[]
  carts                Cart[]
  clientMessageThreads ClientMessageThread[]
  clientProfiles       ClientProfile[]
  clientTasks          ClientTask[]
  complianceReviews    ComplianceReview[]
  complianceScores     ComplianceScore[]
  contactPersons       ContactPerson[]
  crmTasks             CrmTask[]
  dataSubjectRequests  DataSubjectRequest[]
  deals                Deal[]
  documentDownloads    DocumentDownload[]
  documentInputs       DocumentInput[]
  fileAssets           FileAsset[]
  formSubmissions      FormSubmission[]
  generatedDocuments   GeneratedDocument[]
  generationJobs       DocumentGenerationJob[]
  invites              OrganizationInvite[]
  invoices             Invoice[]
  leads                Lead[]
  marketingEvents      MarketingEvent[]
  members              OrganizationUser[]
  notifications        Notification[]
  orders               Order[]
  payments             Payment[]
  refunds              Refund[]
  settings             OrganizationSettings?
  subscribers          NewsletterSubscriber[]
}

model OrganizationUser {
  id             String                   @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationMemberRole   @default(MEMBER)
  status         OrganizationMemberStatus @default(ACTIVE)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@index([userId, status])
}

model OrganizationInvite {
  id             String                   @id @default(cuid())
  organizationId String
  email          String
  role           OrganizationMemberRole   @default(MEMBER)
  status         OrganizationInviteStatus @default(PENDING)
  tokenHash      String                   @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  invitedBy    User?        @relation("OrganizationInviteInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([email, status])
  @@index([expiresAt])
}

model BillingProfile {
  id             String   @id @default(cuid())
  organizationId String
  companyName    String
  taxId          String?
  email          String?
  addressLine1   String?
  addressLine2   String?
  postalCode     String?
  city           String?
  country        String   @default("PL")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices     Invoice[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isDefault])
  @@index([taxId])
}

model OrganizationSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  locale         String   @default("pl-PL")
  timezone       String   @default("Europe/Warsaw")
  settings       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id               String                 @id @default(cuid())
  userId           String
  organizationId   String
  organizationRole OrganizationMemberRole @default(MEMBER)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([organizationRole])
}

model ContactPerson {
  id             String            @id @default(cuid())
  organizationId String
  role           ContactPersonRole @default(OTHER)
  name           String
  email          String?
  phone          String?
  position       String?
  isPrimary      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]
  orders       Order[]

  @@index([organizationId, role])
  @@index([email])
}

model ProductCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([isActive, sortOrder])
}

model Product {
  id              String        @id @default(cuid())
  categoryId      String?
  kind            ProductKind   @default(DOCUMENT)
  status          ProductStatus @default(DRAFT)
  name            String
  slug            String        @unique
  shortName       String?
  description     String?
  fulfillmentDays Int?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  cartItems  CartItem[]
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]
  package    ProductPackage?
  variants   ProductVariant[]

  @@index([categoryId, status])
  @@index([status, createdAt])
  @@index([kind, status])
}

model ProductVariant {
  id               String               @id @default(cuid())
  productId        String
  status           ProductVariantStatus @default(DRAFT)
  sku              String?              @unique
  name             String
  priceCents       Int
  currency         String               @default("PLN")
  vatRateBps       Int                  @default(2300)
  compareAtCents   Int?
  fulfillmentScope Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  cartItems    CartItem[]
  orderItems   OrderItem[]
  packageItems ProductPackageItem[]
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status])
  @@index([status, createdAt])
}

model ProductPackage {
  id        String   @id @default(cuid())
  productId String   @unique
  name      String
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   ProductPackageItem[]
  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductPackageItem {
  id               String   @id @default(cuid())
  packageId        String
  productVariantId String
  quantity         Int      @default(1)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  package        ProductPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@unique([packageId, productVariantId])
  @@index([productVariantId])
}

model Cart {
  id             String     @id @default(cuid())
  organizationId String?
  email          String?
  status         CartStatus @default(ACTIVE)
  currency       String     @default("PLN")
  subtotalCents  Int        @default(0)
  discountCents  Int        @default(0)
  vatCents       Int        @default(0)
  totalCents     Int        @default(0)
  expiresAt      DateTime?
  convertedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  items        CartItem[]
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  orders       Order[]

  @@index([organizationId, status])
  @@index([status, createdAt])
  @@index([email])
}

model CartItem {
  id               String   @id @default(cuid())
  cartId           String
  productId        String
  productVariantId String?
  quantity         Int      @default(1)
  unitPriceCents   Int
  vatRateBps       Int      @default(2300)
  totalCents       Int
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  @@index([cartId])
  @@index([productId])
  @@index([productVariantId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  organizationId  String?
  customerId      String?
  createdById     String?
  cartId          String?
  contactPersonId String?
  status          OrderStatus @default(DRAFT)
  currency        String      @default("PLN")
  subtotalCents   Int         @default(0)
  discountCents   Int         @default(0)
  vatCents        Int         @default(0)
  totalCents      Int         @default(0)
  paidAt          DateTime?
  fulfilledAt     DateTime?
  cancelledAt     DateTime?
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  cart          Cart?          @relation(fields: [cartId], references: [id], onDelete: SetNull)
  contactPerson ContactPerson? @relation(fields: [contactPersonId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  customer      User?          @relation("OrderCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  deals         Deal[]
  invoices      Invoice[]
  items         OrderItem[]
  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  payments      Payment[]
  refunds       Refund[]
  sourceLead    Lead?          @relation("LeadConvertedOrder")

  @@index([organizationId, status])
  @@index([customerId, status])
  @@index([createdById])
  @@index([cartId])
  @@index([status, createdAt])
}

model OrderItem {
  id                 String          @id @default(cuid())
  orderId            String
  productId          String?
  productVariantId   String?
  status             OrderItemStatus @default(PENDING)
  name               String
  quantity           Int             @default(1)
  unitPriceCents     Int
  discountCents      Int             @default(0)
  vatRateBps         Int             @default(2300)
  vatCents           Int             @default(0)
  totalCents         Int
  fulfillmentPayload Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  documentInputs     DocumentInput[]
  generatedDocuments GeneratedDocument[]
  generationJobs     DocumentGenerationJob[]
  order              Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product?                @relation(fields: [productId], references: [id], onDelete: SetNull)
  productVariant     ProductVariant?         @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  refunds            Refund[]

  @@index([orderId, status])
  @@index([productId])
  @@index([productVariantId])
  @@index([status, createdAt])
}

model Payment {
  id                  String          @id @default(cuid())
  orderId             String
  organizationId      String?
  provider            PaymentProvider @default(STRIPE)
  providerPaymentId   String?         @unique
  status              PaymentStatus   @default(PENDING)
  amountCents         Int
  currency            String          @default("PLN")
  capturedAmountCents Int             @default(0)
  refundedAmountCents Int             @default(0)
  failureCode         String?
  failureMessage      String?
  metadata            Json?
  authorizedAt        DateTime?
  paidAt              DateTime?
  failedAt            DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  refunds      Refund[]

  @@index([orderId])
  @@index([organizationId, status])
  @@index([provider, status])
  @@index([status, createdAt])
}

model Invoice {
  id               String        @id @default(cuid())
  invoiceNumber    String        @unique
  orderId          String?
  organizationId   String?
  billingProfileId String?
  status           InvoiceStatus @default(DRAFT)
  issueDate        DateTime?
  dueDate          DateTime?
  paidAt           DateTime?
  currency         String        @default("PLN")
  netAmountCents   Int           @default(0)
  vatAmountCents   Int           @default(0)
  grossAmountCents Int           @default(0)
  fileKey          String?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  billingProfile BillingProfile? @relation(fields: [billingProfileId], references: [id], onDelete: SetNull)
  order          Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([orderId])
  @@index([billingProfileId])
  @@index([status, createdAt])
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  status          CouponStatus @default(ACTIVE)
  percentOffBps   Int?
  amountOffCents  Int?
  currency        String       @default("PLN")
  maxRedemptions  Int?
  redemptionCount Int          @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, expiresAt])
}

model Refund {
  id               String       @id @default(cuid())
  paymentId        String
  orderId          String?
  orderItemId      String?
  organizationId   String?
  status           RefundStatus @default(REQUESTED)
  amountCents      Int
  currency         String       @default("PLN")
  reason           String?
  providerRefundId String?      @unique
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  order        Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem    OrderItem?    @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  payment      Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([orderId])
  @@index([organizationId, status])
  @@index([status, createdAt])
}

model PipelineStage {
  id        String            @id @default(cuid())
  kind      PipelineStageKind
  key       String            @unique
  name      String
  sortOrder Int               @default(0)
  isDefault Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  deals Deal[]
  leads Lead[]
  tasks CrmTask[]

  @@index([kind, sortOrder])
}

model Lead {
  id               String     @id @default(cuid())
  organizationId   String?
  formSubmissionId String?    @unique
  contactPersonId  String?
  ownerId          String?
  stageId          String?
  convertedOrderId String?    @unique
  source           LeadSource @default(MANUAL)
  status           LeadStatus @default(NEW)
  companyName      String
