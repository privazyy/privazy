model SeoMetadata {
  id              String   @id @default(cuid())
  postId          String?  @unique
  title           String?
  metaDescription String?
  canonicalUrl    String?
  schemaJson      Json?
  faqJson         Json?
  noIndex         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  post BlogPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id               String                     @id @default(cuid())
  organizationId   String?
  email            String                     @unique
  status           NewsletterSubscriberStatus @default(PENDING)
  firstName        String?
  lastName         String?
  source           String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  consentIp        String?
  consentUserAgent String?
  consentedAt      DateTime?
  unsubscribedAt   DateTime?
  unsubscribeToken String                     @unique
  metadata         Json?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  organization    Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  events          NewsletterEvent[]
  marketingEvents MarketingEvent[]
  consentRecords  ConsentRecord[]

  @@index([organizationId])
  @@index([status, createdAt])
  @@index([source])
  @@index([createdAt])
}

model NewsletterCampaign {
  id          String                   @id @default(cuid())
  createdById String?
  name        String
  subject     String
  status      NewsletterCampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  metadata    Json?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  createdBy User?             @relation("NewsletterCampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  events    NewsletterEvent[]

  @@index([createdById])
  @@index([status, createdAt])
  @@index([scheduledAt])
  @@index([createdAt])
}

model NewsletterEvent {
  id              String              @id @default(cuid())
  subscriberId    String?
  campaignId      String?
  type            NewsletterEventType
  provider        String?
  providerEventId String?
  metadata        Json?
  createdAt       DateTime            @default(now())

  subscriber NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  campaign   NewsletterCampaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([subscriberId])
  @@index([campaignId])
  @@index([type, createdAt])
  @@index([createdAt])
}

model MarketingEvent {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  leadId         String?
  subscriberId   String?
  eventType      String
  source         String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  path           String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead         Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  subscriber   NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([leadId])
  @@index([subscriberId])
  @@index([eventType, createdAt])
  @@index([source])
  @@index([createdAt])
}

model ConsentRecord {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  leadId         String?
  subscriberId   String?
  type           ConsentType
  status         ConsentStatus @default(GRANTED)
  source         String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  grantedAt      DateTime      @default(now())
  withdrawnAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead         Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  subscriber   NewsletterSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([leadId])
  @@index([subscriberId])
  @@index([type, status])
  @@index([createdAt])
}

model AutomationRule {
  id             String               @id @default(cuid())
  organizationId String?
  createdById    String?
  name           String
  status         AutomationRuleStatus @default(DRAFT)
  trigger        String
  target         String
  conditions     Json?
  actions        Json
  lastRunAt      DateTime?
  errorMessage   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization  Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User?           @relation("AutomationRuleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  runs          AutomationRun[]
  notifications Notification[]

  @@index([organizationId])
  @@index([createdById])
  @@index([status, createdAt])
  @@index([trigger])
  @@index([lastRunAt])
  @@index([createdAt])
}

model AutomationRun {
  id           String              @id @default(cuid())
  ruleId       String
  status       AutomationRunStatus @default(QUEUED)
  triggerEvent String?
  target       String?
  input        Json?
  output       Json?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([ruleId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Notification {
  id             String             @id @default(cuid())
  organizationId String?
  userId         String?
  ruleId         String?
  runId          String?
  type           NotificationType
  status         NotificationStatus @default(PENDING)
  channel        String?
  title          String
  body           String?
  metadata       Json?
  sentAt         DateTime?
  readAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  rule         AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  run          AutomationRun?  @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([ruleId])
  @@index([runId])
  @@index([type, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model FileObject {
  id             String           @id @default(cuid())
  organizationId String?
  uploadedById   String?
  purpose        FilePurpose      @default(OTHER)
  status         FileObjectStatus @default(ACTIVE)
  provider       String           @default("r2")
  bucket         String?
  key            String           @unique
  fileName       String?
  mimeType       String?
  sizeBytes      Int?
  checksum       String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization           Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  uploadedBy             User?                   @relation("FileObjectUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  generatedDocumentFiles GeneratedDocumentFile[]
  breachAttachments      BreachAttachment[]

  @@index([organizationId])
  @@index([uploadedById])
  @@index([purpose, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  entityType     String
  entityId       String
  metadata       Json
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model FormSubmission {
  id             String               @id @default(cuid())
  organizationId String
  formType       String
  status         FormSubmissionStatus @default(DRAFT)
  data           Json
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdBy      User?           @relation(fields: [createdById], references: [id])
  lead           Lead?
  documentInputs DocumentInput[]

  @@index([organizationId])
  @@index([formType])
  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
}
